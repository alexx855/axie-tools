PORT=4021
SKYMAVIS_API_KEY=

# The wallet that receives x402 payments. Use mainnet settlement only.
X402_PAY_TO=0xYourReceivingAddress
X402_NETWORK=eip155:8453
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_AXIE_FLOOR_PRICE=$0.01
X402_MATERIAL_FLOOR_PRICE=$0.01
X402_ACCOUNT_INFO_PRICE=$0.02

# Client-only payment key for paid requests. Do not use a valuable wallet.
EVM_PRIVATE_KEY=0xYourBaseMainnetPrivateKey
API_URL=http://localhost:4021/paid/axie-floor
